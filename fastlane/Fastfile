default_platform(:ios)

platform :ios do
  desc "Собрать подписанный .ipa (App Store / TestFlight) и опционально загрузить в TestFlight"
  lane :release do
    # Временный keychain для CI (создаётся и удаляется автоматически)
    setup_ci

    # Импорт distribution-сертификата (.p12) во временный keychain
    import_certificate(
      certificate_path: "cert.p12",
      certificate_password: ENV["IOS_DIST_CERT_PASSWORD"].to_s,
      keychain_name: "fastlane_tmp_keychain",
      keychain_password: ""
    )

    # Ключ App Store Connect API (.p8, передаётся как base64)
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_P8_BASE64"],
      is_key_content_base64: true
    )

    # Сборка и подпись .ipa вручную указанным профилем
    build_app(
      workspace: "ios/#{ENV['XCWORKSPACE']}",
      scheme: ENV["SCHEME"],
      configuration: "Release",
      export_method: ENV["EXPORT_METHOD"] || "app-store",
      output_directory: "ios/build",
      output_name: "splpro.ipa",
      clean: true,
      xcargs: [
        "DEVELOPMENT_TEAM=#{ENV['APPLE_TEAM_ID']}",
        "CODE_SIGN_STYLE=Manual",
        "PROVISIONING_PROFILE_SPECIFIER='#{ENV['IOS_PROVISIONING_PROFILE_NAME']}'",
        "CODE_SIGN_IDENTITY='Apple Distribution'"
      ].join(" "),
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: {
          ENV["IOS_BUNDLE_ID"] => ENV["IOS_PROVISIONING_PROFILE_NAME"]
        }
      }
    )

    # Опциональная загрузка в TestFlight
    if ENV["UPLOAD_TESTFLIGHT"] == "true"
      upload_to_testflight(
        api_key: api_key,
        ipa: "ios/build/splpro.ipa",
        skip_waiting_for_build_processing: true
      )
    end
  end
end
